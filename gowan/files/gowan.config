config gowan 'main'
	option enabled '0'
	option listen_host '0.0.0.0'
	option listen_port '1080'
	option acl_default 'deny'
	option log_connections '1'
	option check_type 'tcp'
	option check_target '8.8.8.8:53'
	option check_interval '30'
	option check_timeout '5'
	option check_fail_threshold '3'
	option check_rise_threshold '2'
	option api_enabled '0'
	option api_port '9080'
	option sticky '0'
	option sticky_timeout '300'

# WAN backends reference OpenWrt logical interfaces (from /etc/config/network).
# The current IPv4 address is resolved at service start; DHCP renewals that
# change it trigger a seamless SIGHUP reload via hotplug (no dropped
# connections). Each WAN may override the global check_* options.
#
# config wan 'wan1'
# 	option label '4G Router A'
# 	option interface 'wanb'
# 	option ratio '1'
# 	option enabled '1'
# 	option check_type 'http'                # optional per-WAN overrides;
# 	option check_target 'http://host/path'  # absent options inherit the
# 	option check_interval '10'              # globals above
#
# config wan 'wan2'
# 	option label '4G Router B'
# 	option interface 'wanc'
# 	option ratio '2'
# 	option enabled '1'

# ACL rules are applied to the router input chain in config order; first
# match wins, acl_default applies last. An allow rule for the LAN subnet
# is seeded automatically at install.
#
# config acl
# 	option enabled '1'
# 	option verdict 'deny'
# 	list subnet '10.0.99.0/24'
# 	option description 'Guest WiFi - no proxy access'

# Policy rules pin a client IP (or CIDR) to a specific WAN backend.
#
# config policy
# 	option enabled '1'
# 	option name 'My laptop via wan1'
# 	option type 'client_ip'
# 	option match '10.0.1.100'
# 	option wan 'wan1'

# SOCKS5 username/password authentication (RFC 1929).
config auth 'auth'
	option enabled '0'
	option username ''
	option password ''

# Failover notifications, sent by the daemon's health-change hook.
config notify 'alerts'
	option enabled '0'
	option type 'telegram'          # telegram | discord | webhook
	option telegram_bot_token ''
	option telegram_chat_id ''
	option webhook_url ''
	option on_wan_up '1'
	option on_wan_down '1'
