config gowan 'main'
	option enabled '0'
	option listen_host '0.0.0.0'
	option listen_port '1080'
	option acl_default 'deny'
	option log_connections '1'
	option check_type 'tcp'
	option check_target '8.8.8.8:53'
	option check_interval '30'
	option check_timeout '5'
	option check_fail_threshold '3'
	option check_rise_threshold '2'

# WAN backends reference OpenWrt logical interfaces (from /etc/config/network).
# The current IPv4 address is resolved at service start; DHCP renewals that
# change it trigger an automatic reload via hotplug.
#
# config wan 'wan1'
# 	option label '4G Router A'
# 	option interface 'wanb'
# 	option ratio '1'
# 	option enabled '1'
#
# config wan 'wan2'
# 	option label '4G Router B'
# 	option interface 'wanc'
# 	option ratio '2'
# 	option enabled '1'

# ACL rules are applied to the router input chain in config order; first
# match wins, acl_default applies last. An allow rule for the LAN subnet
# is seeded automatically at install.
#
# config acl
# 	option enabled '1'
# 	option verdict 'deny'
# 	list subnet '10.0.99.0/24'
# 	option description 'Guest WiFi - no proxy access'
